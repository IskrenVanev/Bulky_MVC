@model IEnumerable<Product>
@{
    var status = Context.Request.Query["status"].ToString();
    var categoryList = ViewBag.CategoryList as IEnumerable<Category>;
    var allActive = string.IsNullOrEmpty(status) || status.Equals("all", StringComparison.OrdinalIgnoreCase) ? "active text-white bg-primary" : "text-primary";
}


<div class="text-center">
    <img src="~/HomePagePhotos/libraryMainPage.jpg" alt="Library Main Page image" class="img-fluid d-block mx-auto p-3" style="width: 70%; height: auto;" />
    <h1 class ="d-block mx-auto p-3" style="width: 70%; height: auto;">Shop by category</h1>
    <div class="filter-box">
        <div>
            <ul class="list-group list-group-horizontal-sm mx-auto justify-content-center">
                <a style="text-decoration:none;" asp-area="Customer" asp-controller="Home" asp-action="Index" asp-route-status="all">
                    <li class="list-group-item @allActive">
                        All
                    </li>
                </a>

                @if (categoryList != null)
                {
                    foreach (var category in categoryList)
                    {
                        var isActive = status.Equals(category.Name, StringComparison.OrdinalIgnoreCase) ? "active text-white bg-primary" : "text-primary";
                        <a style="text-decoration:none;" asp-area="Customer" asp-controller="Home" asp-action="Index" asp-route-status="@category.Name">
                            <li class="list-group-item @isActive">
                                @category.Name
                            </li>
                        </a>
                    }
                }
            </ul>
        </div>
    </div>

</div>
<div class="row pb-3">
   
    @foreach (var product in Model)
    {
        var category = product.Category?.Name ?? "uncategorized";

        <div class="col-lg-3 col-sm-6 pb-4" data-category="@category">
            <div class="row p-2">
                <div class="col-12 p-1">
                    <div class="card border-0 p-3 shadow border-top border-5 rounded">
                        @if (product.ProductImages != null && product.ProductImages.Count() > 0)
                        {
                            <img src="@product.ProductImages.FirstOrDefault().ImageUrl" class="card-img-top rounded"/>
                        }
                        else
                        {
                            <img src="https://placehold.co/500x600/png" class="card-img-top rounded"/>
                        }

                        <div class="card-body pb-0">
                            <div class="pl-1">
                                <p class="card-title h5 text-dark opacity-75 text-uppercase text-center">@product.Title</p>
                                <p class="card-title text-warning text-center">by <b>@product.Author</b></p>
                            </div>
                            <div class="pl-1">
                                <p class=" text-dark text-opacity-75 text-center mb-0">
                                    List price:
                                    <span class="text-decoration-line-through">
                                        @product.ListPrice.ToString("c")
                                    </span>
                                </p>
                            </div>
                            <div class="pl-1">
                                <p class=" text-dark text-opacity-75 text-center">
                                    As low as:
                                    <span>
                                        @product.Price100.ToString("c")
                                    </span>
                                </p>
                            </div>
                            <a asp-action="Details"
                               asp-route-productId="@product.Id"
                               class="btn btn-primary bg-gradient border-0 form-control">
                                Details
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 mb-5">
            <h1 class="text-center mt-5">Sorry, there are no @(string.IsNullOrEmpty(status) || status.Equals("all", StringComparison.OrdinalIgnoreCase) ? "" : status) books :(</h1>
        </div>
    }
</div>
@section Scripts {
    <script src="~/js/category.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>

}